{
  "name": "one-more",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "npx expo start --dev-client",
    "dev:tunnel": "npx expo start --dev-client --tunnel -c",
    "dev:lan": "npx expo start --dev-client",
    "build": "npx expo prebuild --clean",
    "android": "expo run:android",
    "ios": "npx expo run:ios",
    "ios:device": "npx expo run:ios --device",
    "ios:release": "npx expo run:ios --device --configuration Release",
    "web": "expo start --web",
    "build:ios": "eas build --profile preview --platform ios",
    "build:ios:prod": "eas build --profile production --platform ios",
    "testflight": "eas build --profile production --platform ios && eas submit --profile production --platform ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.12.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
